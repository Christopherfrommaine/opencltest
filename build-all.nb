            ",", "\"\<    u256 a`` = u256_shl(o, ``);\\n\>\"", ",", " ", 
            RowBox[{"Negative", "[", 
             RowBox[{"i", "-", "bits"}], "]"}], ",", 
            " ", "\"\<    u256 a`` = u256_shr(o, ``);\\n\>\"", ",", " ", 
            "True", ",", "\"\<    u256 a`` = o;\\n\>\""}], "]"}], ",", " ", 
          "i", ",", " ", 
          RowBox[{"Abs", "[", 
