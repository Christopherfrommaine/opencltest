             RowBox[{"2", "r"}], "+", "1"}], ")"}], "*", "bits"}]}], "}"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"updateFunction", "=", 
      RowBox[{"f", "[", 
