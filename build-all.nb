       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"TemplateReplace", "[", 
      RowBox[{"\"\<TEMPLATE_BOTTOMBITSMASK\>\"", "->", "bottombitsmask"}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"nthbitmask", "=", 
      RowBox[{"f", "[", 
       RowBox[{"\"\<#define NTHBITSMASK (u256)(``)\>\"", ",", 
        RowBox[{"StringRiffle", "[", 
