      RowBox[{"MinimalBooleanForm", "/@", 
       RowBox[{
        RowBox[{"BooleanFunction", "[", "fullUpdateRule", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", " ", "All", ",", " ", "0"}], "]"}], "]"}]}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"o2", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"ConvertExprToString", "[", 
         RowBox[{"expr", "/.", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Slot", "[", "i", "]"}], "->", 
             RowBox[{"\"\<a\>\"", "<>", 
              RowBox[{"ToString", "[", "i", "]"}]}]}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"i", ",", 
              RowBox[{"bits", "*", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", "r"}], "+", "1"}], ")"}]}]}], "}"}]}], "]"}]}], 
         "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"expr", ",", " ", "o1"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"o3", "=", 
      RowBox[{"StringRiffle", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"f", "[", 
           RowBox[{"\"\<u256_shl((``) & NTHBITSMASK, ``)\>\"", ",", " ", 
            RowBox[{"o2", "[", 
             RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
            RowBox[{"bits", "-", "i"}]}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"i", ",", " ", "bits"}], "}"}]}], "]"}], ",", 
        " ", "\"\< | \>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"bits", "==", "1"}], ",", " ", 
       RowBox[{"o3", "=", 
        RowBox[{"First", "[", "o2", "]"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"preprereqs", "=", 
      RowBox[{"f", "[", "\"\<    u256 o = *oPoint;\\n\>\"", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"prereqs", "=", 
      RowBox[{"StringJoinTable", "[", 
       RowBox[{
        RowBox[{"f", "[", 
