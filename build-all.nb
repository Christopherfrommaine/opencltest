                  RowBox[{"2", "r"}], "+", "1"}], ")"}]}]}], "]"}], ",", " ", 
             
             RowBox[{"{", 
              RowBox[{"i", ",", " ", "64"}], "}"}]}], "]"}], ",", " ", "2"}], 
