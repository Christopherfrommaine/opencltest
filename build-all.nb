      RowBox[{"\"\<TEMPLATE_NTHBITSMASK\>\"", "->", "nthbitmask"}], "]"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"allowedIntegers", "=", 
