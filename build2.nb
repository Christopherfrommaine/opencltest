Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"PointApplyRule", "[", 
    RowBox[{"rule_", ",", "init_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"CellularAutomaton", "[", 
     RowBox[{"rule", ",", " ", "init", ",", " ", "1"}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"2", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Length", "[", "init", "]"}], "+", "1"}], ")"}], "/", 
       "2"}]}], "]"}], "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", "AnalyzeRule", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AnalyzeRule", "[", 
    RowBox[{"{", 
     RowBox[{"n_", ",", " ", "k_", ",", " ", "r_"}], "}"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"AnalyzeRule", "[", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "k", ",", " ", "r"}], "}"}], "]"}], "=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"rule", "=", 
        RowBox[{"{", 
         RowBox[{"n", ",", "k", ",", " ", "r"}], "}"}]}], "}"}], ",", 
      RowBox[{"<|", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\"\<Rule\>\"", "->", "rule"}], ",", " ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "may", " ", "be", " ", "overrided", " ", "by", " ", "a", " ", 
          "totalistic", " ", "rule"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"\"\<NormalRule\>\"", "->", "rule"}], ",", "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"always", " ", 
          RowBox[{"{", 
           RowBox[{
           "booleanfunctionnumber", ",", " ", "colors", ",", " ", "radius"}], 
           "}"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"\"\<Colors\>\"", "->", "k"}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Radius\>\"", "->", "r"}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Totalistic\>\"", "->", "False"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<Number\>\"", "->", "n"}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Quiescent\>\"", "->", 
         RowBox[{"Not", "[", 
          RowBox[{"Positive", "[", 
           RowBox[{"PointApplyRule", "[", 
            RowBox[{"rule", ",", " ", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", " ", 
               RowBox[{
                RowBox[{"2", "r"}], "+", "1"}]}], "]"}]}], "]"}], "]"}], 
          "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Symmetric\>\"", "->", 
         RowBox[{"AllTrue", "[", 
          RowBox[{
           RowBox[{"Tuples", "[", 
            RowBox[{
             RowBox[{"Range", "[", 
              RowBox[{"0", ",", " ", 
               RowBox[{"k", "-", "1"}]}], "]"}], ",", " ", 
             RowBox[{
              RowBox[{"2", "r"}], "+", "1"}]}], "]"}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"PointApplyRule", "[", 
              RowBox[{"rule", ",", " ", "#"}], "]"}], "==", 
             RowBox[{"PointApplyRule", "[", 
              RowBox[{"rule", ",", " ", 
               RowBox[{"Reverse", "[", "#", "]"}]}], "]"}]}], "&"}]}], 
          "]"}]}]}], "\[IndentingNewLine]", "|>"}]}], "]"}]}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AnalyzeRule", "[", 
   RowBox[{"{", 
    RowBox[{"n_", ",", " ", 
     RowBox[{"{", 
      RowBox[{"k_", ",", " ", "1"}], "}"}], ",", " ", "r_"}], "}"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"AnalyzeRule", "[", 
    RowBox[{"{", 
     RowBox[{"n", ",", " ", 
      RowBox[{"{", 
       RowBox[{"k", ",", " ", "1"}], "}"}], ",", " ", "r"}], "}"}], "]"}], "=", 
   RowBox[{"With", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rule", "=", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "1"}], "}"}], ",", " ", "r"}], "}"}]}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"num", "=", 
       RowBox[{"FromDigits", "[", 
        RowBox[{
         RowBox[{"Reverse", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"PointApplyRule", "[", 
             RowBox[{"rule", ",", " ", "#"}], "]"}], "&"}], "/@", 
           RowBox[{"Tuples", "[", 
            RowBox[{
             RowBox[{"Range", "[", 
              RowBox[{"0", ",", " ", 
               RowBox[{"k", "-", "1"}]}], "]"}], ",", " ", 
             RowBox[{
              RowBox[{"2", "r"}], "+", "1"}]}], "]"}]}], "]"}], ",", " ", 
         "k"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"AnalyzeRule", "[", 
        RowBox[{"{", 
         RowBox[{"num", ",", " ", "k", ",", " ", "r"}], "}"}], "]"}], ",", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<Rule\>\"", "->", "rule"}], ",", " ", 
         RowBox[{"\"\<Totalistic\>\"", "->", "True"}]}], "|>"}]}], "]"}]}], 
    "\n", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AnalyzeRule", "[", 
   RowBox[{"{", 
    RowBox[{"n_", ",", " ", "k_"}], "}"}], "]"}], ":=", 
  RowBox[{"AnalyzeRule", "[", 
   RowBox[{"{", 
    RowBox[{"n", ",", " ", "k", ",", " ", "1"}], "}"}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"AnalyzeRule", "[", 
   RowBox[{"{", "n_", "}"}], "]"}], ":=", 
  RowBox[{"AnalyzeRule", "[", 
   RowBox[{"{", 
    RowBox[{"n", ",", " ", "2"}], "}"}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"AnalyzeRule", "[", "n_", "]"}], ":=", 
  RowBox[{"AnalyzeRule", "[", 
   RowBox[{"{", "n", "}"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.991413545102191*^9, 3.99141354698396*^9}, {
