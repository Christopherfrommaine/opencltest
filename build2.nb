Cell[BoxData["\<\"static inline void update_ulong(ulong *restrict oPoint_0, \
ulong *restrict oPoint_1) {\\n    ulong o_0 = *oPoint_0;\\n    ulong o_1 = \
*oPoint_1;\\n\\n    ulong a6 = o_0;\\n    ulong a5 = o_1;\\n    ulong a4 = \
ulong_shl1(o_0);\\n    ulong a3 = ulong_shl1(o_1);\\n    ulong a2 = \
ulong_shl2(o_0);\\n    ulong a1 = ulong_shl2(o_1);\\n\\n    *oPoint_0 = (~ a2 \
& ((a1 & ((~ a5 & a3 & a6) | (~ a3 & a4 & a5))) | (~ a1 & ~ a3 & ~ (a4 & a6) \
& (a4 | a6) & ~ a5))) | (~ a1 & a2 & ((a3 & a5) | (~ a3 & ~ a4 & ~ a5 & ~ \
a6)));\\n    *oPoint_1 = ~ (a1 & a2) & ~ (a1 & a3 & a6) & (~ a1 | a3 | ~ a4 | \
~ a5) & (a1 | a2 | a3 | a4) & (a1 | a2 | a3 | a5) & (a1 | a2 | a5 | a6) & (a1 \
| a3 | a4 | a5) & ~ (a2 & a3 & a5) & (~ a2 | a3 | a5 | a6) & (a3 | a4 | a5 | \
a6);\\n}\\n\"\>"], "Output",
