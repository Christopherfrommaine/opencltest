Cell[BoxData[{
 RowBox[{"Clear", "[", "f", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"formatString_String", ",", " ", "args___"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"str", "=", "formatString"}], ",", " ", 
       RowBox[{"arglist", "=", 
        RowBox[{"{", "args", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"str", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"str", ",", " ", 
           RowBox[{"\"\<``\>\"", "->", 
            RowBox[{"ToString", "[", 
             RowBox[{"arglist", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", "1"}], "]"}]}], ",",
         " ", 
        RowBox[{"{", 
         RowBox[{"i", ",", " ", 
          RowBox[{"Length", "[", "arglist", "]"}]}], "}"}]}], "]"}], ";", " ",
       "str"}]}], "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
