Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"GenerateUpdateFunction", "[", "type_String", "]"}], ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"preprereqs", "=", 
      RowBox[{"StringJoinTable", "[", 
       RowBox[{
        RowBox[{"f", "[", 
         RowBox[{"\"\<    `` o_`` = *oPoint_``;\\n\>\"", ",", " ", "type", ",",
           " ", "i", ",", " ", "i"}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"i", ",", " ", "0", ",", " ", 
          RowBox[{"bits", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"prereqs", "=", 
      RowBox[{"StringJoinTable", "[", 
