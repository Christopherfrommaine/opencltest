                "j", ",", " ", "i"}], "]"}], ",", " ", 
              RowBox[{"f", "[", 
               RowBox[{"\"\<o_``\>\"", ",", " ", "i"}], "]"}]}], "]"}]}], 
           "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"i", ",", " ", "0", ",", " ", 
            RowBox[{"bits", "-", "1"}]}], "}"}]}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"j", ",", " ", "0", ",", " ", 
          RowBox[{"2", "r"}]}], "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"updateExpression", "=", 
      RowBox[{"StringJoinTable", "[", 
       RowBox[{
        RowBox[{"f", "[", 
         RowBox[{"\"\<    *oPoint_`` = ``;\\n\>\"", ",", " ", 
          RowBox[{"i", "-", "1"}], ",", " ", 
          RowBox[{"o2", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", " ", 
        RowBox[{"{", 
