{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build main",
      "type": "process",
      "command": "/usr/bin/make",
      "args": [
        "-f",
        "${workspaceFolder}/Makefile",
        "main"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "clean",
      "type": "process",
      "command": "/usr/bin/make",
      "args": [
        "-f",
        "${workspaceFolder}/Makefile",
        "clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "run main",
      "type": "process",
      "command": "${workspaceFolder}/main",
      "args": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "build main",
      "problemMatcher": []
    }
  ]
}