 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"RandomGoodRule", "[", 
     RowBox[{
      RowBox[{"K_", ":", "2"}], ",", " ", 
      RowBox[{"R_", ":", "1"}]}], "]"}], ":=", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"rca", "=", 
       RowBox[{
       "ResourceFunction", "[", "\"\<RandomCellularAutomatonRule\>\"", 
        "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"GoodRuleCondition", "[", "rule_", "]"}], ":=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", 
           RowBox[{"Last", "[", 
            RowBox[{"CellularAutomaton", "[", 
             RowBox[{"rule", ",", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"RandomInteger", "[", 
                 RowBox[{
                  RowBox[{"K", "-", "1"}], ",", " ", "100"}], "]"}], ",", " ",
                 "0"}], "}"}], ",", " ", "100"}], "]"}], "]"}], "]"}], ">", 
          "150"}], ",", " ", "False", ",", " ", 
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"l", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Length", "[", 
                RowBox[{"StripZeros", "[", 
                 RowBox[{"CellularAutomaton", "[", 
                  RowBox[{"rule", ",", " ", 
                   RowBox[{"{", 
