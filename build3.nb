                    RowBox[{"RandomInteger", "[", 
                    RowBox[{
                    RowBox[{"K", "-", "1"}], ",", " ", "100"}], "]"}], ",", 
                    " ", "0"}], "}"}], ",", " ", 
                   RowBox[{"{", 
                    RowBox[{"{", 
                    RowBox[{"{", "100", "}"}], "}"}], "}"}]}], "]"}], "]"}], 
                "]"}], ",", " ", "10"}], "]"}]}], "}"}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"Mean", "[", "l", "]"}], "<", "100"}], "&&", 
            RowBox[{
             RowBox[{"Min", "[", "l", "]"}], "==", "0"}], "&&", 
            RowBox[{
             RowBox[{"Max", "[", "l", "]"}], "<", "150"}], "&&", 
            RowBox[{
             RowBox[{"Max", "[", "l", "]"}], ">", "0"}]}]}], "]"}]}], "]"}]}],
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"ParallelTry", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"If", "[", 
