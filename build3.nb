  RowBox[{"RepeatedRotate", "[", 
   RowBox[{"list_List", ",", " ", 
    RowBox[{"factor_Integer", ":", "1"}]}], "]"}], ":=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"RotateRight", "[", 
     RowBox[{
      RowBox[{"list", "[", 
