Cell[BoxData[
 RowBox[{
  RowBox[{"ColorConjugateRule", "[", "n_", "]"}], ":=", 
  RowBox[{"FromDigits", "[", 
   RowBox[{
    RowBox[{"Reverse", "[", 
     RowBox[{"1", "-", 
      RowBox[{"IntegerDigits", "[", 
       RowBox[{"n", ",", "2", ",", "8"}], "]"}]}], "]"}], ",", "2"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.991486687299902*^9, 3.9914867124050922`*^9}},
 CellLabel->
  "In[136]:=",ExpressionUUID->"60e0dfc2-6637-4e0b-a2e8-7d1d0821460f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ColorConjugateRuleGeneralized", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n_", ",", " ", "k_", ",", " ", "r_"}], "}"}], ",", " ", 
    "shift_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"FromDigits", "[", 
     RowBox[{
      RowBox[{"Values", "[", 
       RowBox[{"ReverseSort", "[", 
        RowBox[{
         RowBox[{"Thread", "[", 
          RowBox[{
           RowBox[{"Tuples", "[", 
            RowBox[{
             RowBox[{"Range", "[", 
              RowBox[{"0", ",", " ", 
               RowBox[{"k", "-", "1"}]}], "]"}], ",", " ", 
             RowBox[{
              RowBox[{"2", "r"}], "+", "1"}]}], "]"}], "->", 
           RowBox[{"Reverse", "[", 
            RowBox[{"IntegerDigits", "[", 
             RowBox[{"n", ",", " ", "k", ",", " ", 
              RowBox[{"k", "^", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", "r"}], "+", "1"}], ")"}]}]}], "]"}], "]"}]}], 
          "]"}], "/.", 
         RowBox[{"i_Integer", ":>", 
          RowBox[{"Mod", "[", 
           RowBox[{
            RowBox[{"i", "-", "shift"}], ",", " ", "k"}], "]"}]}]}], "]"}], 
       "]"}], ",", " ", "k"}], "]"}], ",", "k", ",", " ", "r"}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.9914867195793858`*^9, 3.99148672809168*^9}, {
   3.9914871304036417`*^9, 3.99148713523691*^9}, {3.991487235344667*^9, 
   3.991487235439672*^9}, 3.991487518884659*^9, {3.991487962840852*^9, 
   3.991487976512883*^9}},
 CellLabel->
  "In[137]:=",ExpressionUUID->"06a0037b-fb3c-4e79-8dd7-3100835c5e38"],

