Cell[BoxData["\<\"#ifdef __APPLE__\\ninline uint ctz(ulong x)\\n{\\n    if (x \
== 0UL) {\\n        return 64u;\\n    }\\n\\n    return (uint)(63u - clz(x & \
(~x + 1UL)));\\n}\\n#endif\\n\"\>"], "Output",
