Cell[BoxData[
 RowBox[{
  RowBox[{"MinimalBooleanForm", "[", "bf_", "]"}], ":=", 
  RowBox[{"First", "[", 
   RowBox[{"MinimalBy", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Join", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"First", "[", 
          RowBox[{"BooleanMinimize", "[", 
           RowBox[{"bf", ",", " ", "#"}], "]"}], "]"}], "&"}], "/@", 
        RowBox[{"{", 
         RowBox[{"\"\<DNF\>\"", ",", "\"\<CNF\>\"", ",", "\"\<ANF\>\"", ",", 
          " ", "\"\<NOR\>\"", ",", " ", "\"\<NAND\>\"", ",", "\"\<AND\>\"", ",",
           " ", "\"\<OR\>\""}], "}"}]}], ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"FullSimplify", "[", 
          RowBox[{"First", "[", 
           RowBox[{"BooleanConvert", "[", 
            RowBox[{"bf", ",", " ", "#"}], "]"}], "]"}], "]"}], "&"}], "/@", 
        RowBox[{"{", 
         RowBox[{"\"\<ESOP\>\"", ",", " ", "\"\<NOR2\>\"", ",", 
          " ", "\"\<NAND2\>\"", ",", " ", "\"\<BDT\>\""}], "}"}]}]}], 
      "\[IndentingNewLine]", "]"}], ",", " ", "\[IndentingNewLine]", 
