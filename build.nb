Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "SolidColorGoesTo", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SolidColorGoesTo", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n_", ",", " ", "k_", ",", " ", "r_"}], "}"}], ",", "color_"}], 
   "]"}], ":=", 
  RowBox[{"PointApplyRule", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", ",", " ", "k", ",", " ", "r"}], "}"}], ",", " ", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"color", ",", " ", 
      RowBox[{
       RowBox[{"2", "r"}], "+", "1"}]}], "]"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.99148116097281*^9, 3.9914812635817423`*^9}, {
   3.991481297907777*^9, 3.991481410728717*^9}, {3.991481473232203*^9, 
   3.991481483456238*^9}, {3.9914819584755583`*^9, 3.9914819653800697`*^9}, 
   3.991482003296908*^9},
 CellLabel->
  "In[130]:=",ExpressionUUID->"39d2c9bd-8904-4cc8-bd07-137ba4fe0f41"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"colorCycleGraph", "=", 
   RowBox[{"Graph", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"#", "->", 
        RowBox[{"SolidColorGoesTo", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"n", ",", "k", ",", "r"}], "}"}], ",", " ", "#"}], "]"}]}],
        "&"}], "/@", 
      RowBox[{"Range", "[", 
       RowBox[{"0", ",", " ", 
        RowBox[{"k", "-", "1"}]}], "]"}]}], ",", " ", 
     RowBox[{"VertexLabels", "->", "Automatic"}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"subgraphWithZeroBackground", "=", 
   RowBox[{"Subgraph", "[", 
    RowBox[{"colorCycleGraph", ",", 
     RowBox[{"SelectFirst", "[", 
      RowBox[{
       RowBox[{"WeaklyConnectedComponents", "[", "colorCycleGraph", "]"}], ",", 
       RowBox[{"MemberQ", "[", "0", "]"}]}], "]"}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"StrongAssert", "[", 
   RowBox[{
    RowBox[{"!", 
     RowBox[{"AcyclicGraphQ", "[", "subgraphWithZeroBackground", "]"}]}], 
    ",", "\"\<Error: Color sequence contains cycles! \>\"", ",", 
    RowBox[{"First", "[", 
     RowBox[{"FindCycle", "[", "subgraphWithZeroBackground", "]"}], "]"}]}], 
   "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"backgroundcolor", "=", 
  RowBox[{
   RowBox[{"Cases", "[", 
    RowBox[{
     RowBox[{"EdgeList", "[", "subgraphWithZeroBackground", "]"}], ",", 
     RowBox[{"x_", "\[DirectedEdge]", "x_"}]}], "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"1", ",", " ", "1"}], "]"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.991481487814633*^9, 3.991481504693716*^9}, {
