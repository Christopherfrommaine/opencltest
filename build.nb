 RowBox[{
  RowBox[{"Clear", "[", "AnalyzeRule", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AnalyzeRule", "[", 
    RowBox[{"{", 
     RowBox[{"n_", ",", " ", "k_", ",", " ", "r_"}], "}"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"AnalyzeRule", "[", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "k", ",", " ", "r"}], "}"}], "]"}], "=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"rule", "=", 
        RowBox[{"{", 
         RowBox[{"n", ",", "k", ",", " ", "r"}], "}"}]}], "}"}], ",", 
      RowBox[{"<|", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\"\<Rule\>\"", "->", "rule"}], ",", " ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "may", " ", "be", " ", "overrided", " ", "by", " ", "a", " ", 
          "totalistic", " ", "rule"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"\"\<NormalRule\>\"", "->", "rule"}], ",", "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"always", " ", 
          RowBox[{"{", 
           RowBox[{
           "booleanfunctionnumber", ",", " ", "colors", ",", " ", "radius"}], 
           "}"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"\"\<Colors\>\"", "->", "k"}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Radius\>\"", "->", "r"}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Totalistic\>\"", "->", "False"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<Number\>\"", "->", "n"}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Quiescent\>\"", "->", 
         RowBox[{"Not", "[", 
          RowBox[{"Positive", "[", 
           RowBox[{"PointApplyRule", "[", 
            RowBox[{"rule", ",", " ", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"0", ",", " ", 
               RowBox[{
                RowBox[{"2", "r"}], "+", "1"}]}], "]"}]}], "]"}], "]"}], 
          "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Symmetric\>\"", "->", 
         RowBox[{"AllTrue", "[", 
          RowBox[{
           RowBox[{"Tuples", "[", 
            RowBox[{
             RowBox[{"Range", "[", 
              RowBox[{"0", ",", " ", 
               RowBox[{"k", "-", "1"}]}], "]"}], ",", " ", 
             RowBox[{
              RowBox[{"2", "r"}], "+", "1"}]}], "]"}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"PointApplyRule", "[", 
              RowBox[{"rule", ",", " ", "#"}], "]"}], "==", 
             RowBox[{"PointApplyRule", "[", 
              RowBox[{"rule", ",", " ", 
               RowBox[{"Reverse", "[", "#", "]"}]}], "]"}]}], "&"}]}], 
          "]"}]}]}], "\[IndentingNewLine]", "|>"}]}], "]"}]}]}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"AnalyzeRule", "[", 
   RowBox[{"{", 
    RowBox[{"n_", ",", " ", 
     RowBox[{"{", 
      RowBox[{"k_", ",", " ", "1"}], "}"}], ",", " ", "r_"}], "}"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"AnalyzeRule", "[", 
